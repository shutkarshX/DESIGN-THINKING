function renderQuiz() {
  const el = document.getElementById("learn-quiz");
  if (!state.quizDone) {
    const q = QUIZ_QUESTIONS[state.quizIdx];
    const pct = (state.quizIdx / QUIZ_QUESTIONS.length) * 100;
    el.innerHTML = `
      <div class="flex-between" style="margin-bottom:16px">
        <span class="text-muted text-sm">Question ${state.quizIdx+1} of ${QUIZ_QUESTIONS.length}</span>
        <span style="font-size:13px;font-weight:700;color:var(--green-600)">Score: ${state.quizScore}</span>
      </div>
      <div class="progress-bar" style="margin-bottom:24px"><div class="progress-fill" style="width:${pct}%"></div></div>
      <div class="card" style="background:var(--green-100);border:1.5px solid var(--green-200);margin-bottom:20px">
        <div style="font-size:16px;font-weight:700;color:var(--green-900);line-height:1.4">🤔 ${q.q}</div>
      </div>
      ${q.options.map((opt,i)=>`
        <button class="quiz-opt ${state.quizSelected===null?'':i===q.answer?'correct':state.quizSelected===i?'wrong':''}" onclick="answerQuiz(${i})" ${state.quizSelected!==null?'disabled':''}>
          <span style="margin-right:10px;font-weight:700">${["A","B","C","D"][i]}.</span>${opt}
        </button>
      `).join("")}
    `;
  } else {
    const emoji = state.quizScore>=4?"🏆":state.quizScore>=3?"🎉":"📚";
    const msg = state.quizScore>=4?"Excellent! You're a waste management pro!":state.quizScore>=3?"Good job! Keep learning!":"Keep practicing to become an eco expert!";
    el.innerHTML = `
      <div class="quiz-complete">
        <div style="font-size:60px;margin-bottom:16px">${emoji}</div>
        <h3 style="font-family:'Syne',sans-serif;font-size:24px;font-weight:800;color:var(--green-900);margin-bottom:8px">Quiz Complete!</h3>
        <div class="quiz-score">${state.quizScore}/${QUIZ_QUESTIONS.length}</div>
        <p style="color:var(--text-muted);font-size:14px;margin-bottom:24px">${msg}</p>
        ${state.quizScore>=3&&!state.quizRewarded?`<div style="background:var(--green-100);border-radius:14px;padding:14px;margin-bottom:20px"><span style="font-size:14px;color:var(--green-900);font-weight:600">🌟 Claim your 5 bonus points!</span></div>`:""}
        <button class="btn btn-primary full-btn" style="margin-bottom:10px" onclick="retryQuiz()">
          ${state.quizScore>=3&&!state.quizRewarded&&state.currentUser?"Claim Bonus & Retry":"Try Again"}
        </button>
        ${state.quizScore>=3&&!state.quizRewarded&&state.currentUser?`<button class="btn btn-outline full-btn" onclick="claimQuizBonus()">Claim Bonus Points</button>`:""}
      </div>
    `;
  }
}

function answerQuiz(idx) {
  if (state.quizSelected !== null) return;
  state.quizSelected = idx;
  if (idx === QUIZ_QUESTIONS[state.quizIdx].answer) state.quizScore++;
  renderQuiz();
  setTimeout(() => {
    if (state.quizIdx + 1 >= QUIZ_QUESTIONS.length) {
      state.quizDone = true;
    } else {
      state.quizIdx++;
      state.quizSelected = null;
    }
    renderQuiz();
  }, 1200);
}

function retryQuiz() {
  if (state.quizScore>=3 && !state.quizRewarded && state.currentUser) claimQuizBonus();
  state.quizIdx = 0; state.quizSelected = null; state.quizScore = 0; state.quizDone = false;
  renderQuiz();
}

function claimQuizBonus() {
  if (state.quizRewarded || !state.currentUser || state.quizScore < 3) return;
  state.users = state.users.map(u => u.id===state.currentUser.id ? { ...u, points: u.points+5 } : u);
  state.currentUser = { ...state.currentUser, points: state.currentUser.points+5 };
  state.quizRewarded = true;
  ss("swrs_quiz_done", true);
  saveState();
  showToast("🎉 +5 bonus points for acing the quiz!");
  renderHeader();
  renderQuiz();
}

