        <input type="number" placeholder="Manual pts" id="ep-${u.id}" style="padding:8px 10px;font-size:12px">
        <button class="btn btn-primary btn-sm" onclick="adminAdjustPts('${u.id}',1)">Add</button>
        <button class="btn btn-danger btn-sm" onclick="adminAdjustPts('${u.id}',-1)">Deduct</button>
      </div>
    </div>
  `).join("");
}

function adminAdjustPts(userId, direction) {
  const input = document.getElementById("ep-"+userId);
  const val = parseInt(input?.value);
  if (!val) return;
  const delta = direction * val;
  state.users = state.users.map(u => u.id===userId ? { ...u, points: Math.max(0,u.points+delta) } : u);
  if (state.currentUser?.id === userId) state.currentUser = { ...state.currentUser, points: Math.max(0,state.currentUser.points+delta) };
  saveState();
  showToast(`Points adjusted by ${delta>0?"+":""}${delta}`);
  renderAdminUsers();
  renderHeader();
}

function renderAdminLogs() {
  const el = document.getElementById("admin-logs");
  const total = state.logs.reduce((s,l)=>s+l.weightGrams,0);
  const totalPts = state.logs.reduce((s,l)=>s+l.points,0);
  el.innerHTML = `
    <div class="admin-stats">
      <div class="admin-stat-pill"><div class="admin-stat-val">${state.logs.length}</div><div class="admin-stat-lbl">Total Logs</div></div>
      <div class="admin-stat-pill"><div class="admin-stat-val">${(total/1000).toFixed(1)}kg</div><div class="admin-stat-lbl">Total Waste</div></div>
      <div class="admin-stat-pill"><div class="admin-stat-val">${totalPts}</div><div class="admin-stat-lbl">Pts Awarded</div></div>
    </div>
    ${state.logs.slice(0,15).map(l => {
      const user = state.users.find(u=>u.id===l.userId);
      const wt = WASTE_TYPES.find(w=>w.id===l.wasteType);
      return `<div class="admin-log-item">
        <span style="font-size:18px">${wt?.icon}</span>
        <div style="flex:1">
          <span style="font-weight:600;color:var(--green-900)">${user?.name?.split(" ")[0]||"?"}</span>
          <span style="color:var(--text-muted)"> · ${wt?.label} · ${l.weightGrams}g</span>
        </div>
        <span style="font-weight:700;color:var(--green-600);font-size:12px">+${l.points}</span>
      </div>`;
    }).join("")}
  `;
}

function renderAdminRewards() {
  const el = document.getElementById("admin-rewards");
  el.innerHTML = `
    <div class="card" style="margin-bottom:20px">
      <h3 style="font-size:14px;font-weight:700;color:var(--green-900);margin-bottom:14px">Add New Reward</h3>
      <input type="text" id="nr-name" placeholder="Reward name" style="margin-bottom:10px">
      <div class="grid-2" style="margin-bottom:10px">
        <input type="number" id="nr-points" placeholder="Points required">
        <input type="number" id="nr-stock" placeholder="Stock" value="10">
      </div>
      <div class="grid-2" style="margin-bottom:14px">
        <input type="text" id="nr-icon" placeholder="Icon (emoji)" value="🎁">
        <select id="nr-category">
          <option>Food</option><option>Voucher</option><option>Gift</option>
        </select>
      </div>
      <button class="btn btn-primary full-btn" style="font-size:13px" onclick="adminAddReward()">+ Add Reward</button>
    </div>
    ${state.rewards.map(r=>`
      <div class="reward-manage-item">
        <span style="font-size:28px">${r.icon}</span>
        <div style="flex:1">
          <div style="font-size:13px;font-weight:700;color:var(--green-900)">${r.name}</div>
          <div style="font-size:11px;color:var(--text-muted)">⭐ ${r.points} pts · ${r.stock} in stock</div>
        </div>
        <button onclick="adminRemoveReward('${r.id}')" style="background:#fdf0f0;color:var(--red);border:none;border-radius:8px;padding:7px 12px;font-size:12px;font-weight:700;cursor:pointer;font-family:inherit">Remove</button>
      </div>
    `).join("")}
  `;
}

function adminAddReward() {
  const name   = document.getElementById("nr-name")?.value?.trim();
  const points = parseInt(document.getElementById("nr-points")?.value);
  const stock  = parseInt(document.getElementById("nr-stock")?.value) || 10;
  const icon   = document.getElementById("nr-icon")?.value || "🎁";
  const cat    = document.getElementById("nr-category")?.value || "Food";
  if (!name || !points) return;
  state.rewards.push({ id:genId(), name, points, icon, category:cat, stock });
  saveState();
  showToast("Reward added!");
  renderAdminRewards();
}

function adminRemoveReward(id) {
  state.rewards = state.rewards.filter(r=>r.id!==id);
  saveState();
  showToast("Reward removed.");
  renderAdminRewards();
}

